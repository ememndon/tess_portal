# Tess Portal environment. Copy to .env and fill in. The real .env is
# generated by scripts/generate-env.sh, is chmod 600, and never enters
# git or a Docker image.

NODE_ENV=production
APP_URL=https://career.tessconsole.cloud
LOG_LEVEL=info

# PostgreSQL (internal network only, never published)
POSTGRES_USER=tessportal
POSTGRES_PASSWORD=<generated>
POSTGRES_DB=tessportal
DATABASE_URL=postgres://tessportal:<generated>@tessportal-db:5432/tessportal

# Redis
REDIS_PASSWORD=<generated>
REDIS_URL=redis://:<generated>@tessportal-redis:6379/0

# Meilisearch
MEILI_MASTER_KEY=<generated>
MEILI_HOST=http://tessportal-search:7700

# Secret Vault master key, 32 bytes hex for AES-256-GCM. Losing this key
# makes every vault record unreadable. Back it up separately.
VAULT_MASTER_KEY=<generated 64 hex chars>

# Session cookie HMAC signing secret
SESSION_SECRET=<generated>

# Worker
WORKER_HEALTH_PORT=3001
WORKER_INTERNAL_URL=http://tessportal-worker:3001
